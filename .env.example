# ---- Server ----
APP_ENV=development
API_PORT=8080
JWT_SECRET=change-me-to-a-long-random-string
# Must be a publicly reachable URL once hosted — embedded in outreach emails
# as the open-tracking pixel and unsubscribe link. localhost is fine for dev.
APP_BASE_URL=http://localhost:8080
# Dashboard login — single admin user, no user table in this build's schema.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
API_RATE_LIMIT_PER_MIN=120
# "*" is fine for local dev. Set to the dashboard's exact origin
# (scheme+host+port, e.g. https://outreach.watchup.site:7070) once hosted.
CORS_ALLOWED_ORIGIN=*
# Baked into the frontend's JS bundle at build time (see docker-compose.yml).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Host-side ports for docker-compose.yml's port mappings — override only the
# ones that collide with something else already running on the host (3000 is
# a common default other apps use, so it's the most likely to need moving).
FRONTEND_HOST_PORT=3041
# API_HOST_PORT=8080
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379

# ---- Postgres ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=watchup
POSTGRES_PASSWORD=watchup
POSTGRES_DB=watchup

# ---- Redis ----
REDIS_ADDR=localhost:6379

# ---- AI (GROQ ONLY) ----
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
PROMPTS_DIR=../prompts

# Retained but unused by the active provider wiring (gemini package still
# compiles/tests as an alternate ai.Provider implementation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Email: Hostinger ----
# SMTP_USERNAME/PASSWORD authenticate the mailbox; SENDER_EMAIL below is the
# "From" address used when composing outreach (may be a different mailbox
# with send-as permission, e.g. partnership@watchup.space).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993

# ---- Sending policy ----
SENDER_EMAIL=partnership@watchup.space
DAILY_LIMIT=25
SEND_DELAY_MIN_SECONDS=45
SEND_DELAY_MAX_SECONDS=240
SEND_MODE=manual

# ---- Discovery ----
# Comma-separated: github, rss, product_hunt, yc_directory, ai_directory, saas_directory
# (product_hunt/yc_directory/ai_directory/saas_directory are stubs until endpoints/creds are wired up)
DISCOVERY_SOURCES=github,rss
# Optional PAT — GitHub Search API works unauthenticated but at a much lower
# rate limit (~10 req/min). No special scopes needed, it only reads public data.
GITHUB_TOKEN=
# Comma-separated — one GitHubOrgsSource (and one GitHub API search) per query.
GITHUB_ORGS_QUERY=developer tools,API platform,backend framework,devops,SaaS backend,open source infrastructure
# Comma-separated feed URLs. hnrss.org/show = Hacker News "Show HN" launches —
# real, verified-working, and skews heavily toward early-stage dev-tool/infra
# products, a good fit for an error-tracking/observability platform's audience.
RSS_FEED_URLS=https://hnrss.org/show

# ---- Validation ----
# Live RCPT TO probe; off by default to protect sender reputation.
EMAIL_VALIDATION_SMTP_PROBE=false
